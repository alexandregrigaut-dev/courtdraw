# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs — copy each from Dashboard → Products → click the price → API ID
STRIPE_PRICE_ID_PRO_MONTHLY=price_...
STRIPE_PRICE_ID_PRO_YEARLY=price_...
STRIPE_PRICE_ID_CLUB=price_...

# Firebase client-side — also paste these into src/firebase.js
FIREBASE_API_KEY=
FIREBASE_PROJECT_ID=courtdraw
FIREBASE_APP_ID=

# Firebase Admin — from service account JSON (Netlify Functions only, never client-side)
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Resend — verify courtdraw.app as a sending domain in Resend dashboard first
RESEND_API_KEY=

# App
PUBLIC_URL=https://courtdraw.app
SUPPORT_EMAIL=hello@courtdraw.app
